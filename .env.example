# Supabase Configuration
# Get these from https://supabase.co - create a new project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Workspace
WORKSPACE_ID=default-workspace

# AWS Configuration (for S3 + SQS, optional for local dev)
AWS_S3_BUCKET=memward-sessions
AWS_REGION=us-east-1
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/memward-ingest

# Processor API — run with: make dev-processor (port 8010)
# PROCESSOR_TIMEOUT_SECONDS is how long the core API waits for the processor
# before returning 202 anyway. 3s is intentional: ingest is fire-and-forget.
PROCESSOR_API_URL=http://127.0.0.1:8010
PROCESSOR_TIMEOUT_SECONDS=3.0

# LLM provider — OpenRouter (https://openrouter.ai) or any OpenAI-compatible endpoint
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_CHAT_MODEL=openai/gpt-4o-mini
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Backward-compatible legacy key (optional)
# ANTHROPIC_API_KEY=sk-ant-v0-...

# App Debug Mode
DEBUG=false
